{
  "name": "@ohana/cli",
  "version": "0.5.0",
  "description": "Ohana CLI — CI tooling for Salesforce Agent Script",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "ohana": "./dist/bin/ohana.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ohana/core": "workspace:*",
    "@ohana/lint": "workspace:*",
    "@ohana/sim": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
